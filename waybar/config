{
    "layer": "top",
    "exclusive": true,
    "modules-right": ["cpu", "memory", "backlight", "pulseaudio", "battery", "network", "clock"],
    "modules-left": ["custom/power", "niri/workspaces"],

    "custom/power": {
        "format": "  έΠ╗  ",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh",
    },

    "niri/workspaces": {
	    "format": "{icon}",
	    "format-icons": {
		    "browser": "ΌΑΘ",
		    "chat": "<b>ΎΒ╡</b>",
		    "active": "ΎΗΤ",
		    "default": "ΎΕΣ",
	    }
    },

    "cpu": {
        "format": "  ΎΜδ {usage}%  ",
        "interval": 1,
    },

    "memory": {
        "format": "  Ό┐Ζ  {used:0.1f}G/{total:0.1f}G  ",
        "interval": 1,
    },

    "backlight": {
        "format": "  {icon} {percent}%  ",
        "format-icons": ["≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ"],
    },

    "pulseaudio": {
        "format": "  {icon} {volume}%  ",
        "format-muted": "  ΎΑο muted  ",
        "format-icons": {
            "default": ["ΎΑπ", "ΎΑρ"],
            "muted": ["ΎΑο"],
        },
        "tooltip-format": "{desc} ({volume}%)",
        "on-click": "~/.config/waybar/scripts/audio.sh",
    },

    "battery": {
        "format": "  {icon} {capacity}%  ",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-charging": "  {icon} {capacity}% ≤░γξ  ",
        "interval": 1
    },

    "network": {
	    "interface": "wlp1s0",
	    "format": "{ifname}",
	    "format-wifi": "  {essid}  ΎΘτ  ({signalStrength}%)  ",
	    "format-ethernet": "  {ifname} ΎΔΒ  ",
	    "format-disconnected": "  no connection  ",
	    "max-length": 50,
        "on-click": "~/.config/waybar/scripts/nmtui.sh",
        "interval": 1

    },

    "clock": {
        "format": "  {:%H:%M}  ",
        "format-alt": "  {:%a, %d. %b  %H:%M}  ",
        "tooltip-format": "<tt>{calendar}</tt>"
    },
}
