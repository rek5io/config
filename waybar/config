{
    "layer": "top",
    "exclusive": true,
    "modules-right": ["cpu", "memory", "backlight", "pulseaudio", "battery", "network", "clock"],
    "modules-left": ["custom/power"],

    "network": {
	    "interface": "wlp1s0",
	    "format": "{ifname}",
	    "format-wifi": "[ {essid} ΎΘτ ]",
	    "format-ethernet": "{ifname} ΎΔΒ",
	    "format-disconnected": "ΎΒ▓",
	    "max-length": 50,
        "on-click": "~/.config/waybar/scripts/nmtui.sh"
    },

    "custom/power": {
        "format": "[ έΠ╗ ]",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh",
    },

    "battery": {
        "format": "[ {icon} {capacity}% ]",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-charging": "[ {icon} {capacity}% ≤▒Ρξ ]",
        "interval": 1
    },

    "clock": {
        "format": "[ {:%H:%M} ]",
        "format-alt": "[ {:%a, %d. %b  %H:%M} ]",
        "tooltip": false,
    },

    "cpu": {
        "format": "[ΎΜδ {usage}% ]",
        "interval": 1,
    },

    "memory": {
        "format": "[ Ό┐Ζ  {}% ]",
        "interval": 1,
    },

    "backlight": {
        "format": "[ {icon} {percent}% ]",
        "format-icons": ["≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ"],
    },

    "pulseaudio": {
        "format": "[ {icon} {volume}% ]",
        "format-muted": "ΎΑο muted",
        "format-icons": {
            "default": ["ΎΑπ", "ΎΑρ"],
            "muted": ["ΎΑο"],
        },

        "on-click": "~/.config/waybar/scripts/audio.sh",
    },
}
